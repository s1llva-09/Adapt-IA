# ============================================================
# Adapt IA - Exemplo de variaveis de ambiente do backend
# ============================================================
# Copie este arquivo para ".env" dentro da pasta backend:
#
#   backend/.env.example -> backend/.env
#
# Nunca envie o arquivo .env real para o GitHub, pois ele contem chaves privadas.


# ============================================================
# Servidor
# ============================================================
# Porta usada pelo Express.
# O front-end espera encontrar o backend em http://127.0.0.1:3000 por padrao.
PORT=3000


# ============================================================
# Chaves das APIs de IA
# ============================================================
# Chave da OpenAI usada quando o provedor escolhido for OpenAI.
OPENAI_API_KEY=sua_chave_openai_aqui

# Chave do Google Gemini usada para chat, analise de imagens e analise de PDFs.
GEMINI_API_KEY=sua_chave_gemini_aqui


# ============================================================
# Configuracoes opcionais de modelos
# ============================================================
# Estas variaveis documentam a configuracao desejada dos modelos.
# No backend atual, alguns nomes de modelo ainda estao definidos direto nos services,
# mas manter estas variaveis aqui facilita uma configuracao futura pelo .env.

# Lista de modelos Gemini preferidos para texto, separados por virgula.
GEMINI_CHAT_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash

# Lista de modelos Gemini preferidos para imagem/PDF, separados por virgula.
GEMINI_IMAGE_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash

# Tempo maximo de espera para respostas de texto, em milissegundos.
GEMINI_MODEL_TIMEOUT_MS=12000

# Tempo maximo de espera para respostas de imagem/PDF, em milissegundos.
GEMINI_IMAGE_TIMEOUT_MS=15000
